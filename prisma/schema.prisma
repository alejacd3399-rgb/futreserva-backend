generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String         @id @default(uuid())
  businessName  String         @map("business_name")
  slug          String         @unique
  nit           String?
  phone         String?
  email         String?
  address       String?
  logoUrl       String?        @map("logo_url")
  timezone      String         @default("America/Bogota")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  bookings      Booking[]
  customers     Customer[]
  fields        Field[]
  licenses      License[]
  loyaltyConfig LoyaltyConfig?
  tenantUsers   TenantUser[]

  @@map("tenants")
}

model License {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  planName         String   @map("plan_name")
  price            Float
  startsAt         DateTime @map("starts_at")
  expiresAt        DateTime @map("expires_at")
  status           String   @default("active")
  paymentReference String?  @map("payment_reference")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@map("licenses")
}

model TenantUser {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  stackAuthId     String    @unique @map("stack_auth_id")
  email           String
  fullName        String    @map("full_name")
  role            String    @default("staff")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBookings Booking[]
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@map("tenant_users")
}

model Field {
  id           String          @id @default(uuid())
  tenantId     String          @map("tenant_id")
  name         String
  fieldType    String          @map("field_type")
  pricePerHour Float           @map("price_per_hour")
  surface      String          @default("synthetic")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")
  bookings     Booking[]
  schedules    FieldSchedule[]
  tenant       Tenant          @relation(fields: [tenantId], references: [id])

  @@map("fields")
}

model FieldSchedule {
  id                  String   @id @default(uuid())
  fieldId             String   @map("field_id")
  tenantId            String   @map("tenant_id")
  dayOfWeek           Int      @map("day_of_week")
  openTime            String   @map("open_time")
  closeTime           String   @map("close_time")
  slotDurationMinutes Int      @default(60) @map("slot_duration_minutes")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  field               Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@map("field_schedules")
}

model Customer {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  phone             String
  fullName          String    @map("full_name")
  email             String?
  reservationsCount Int       @default(0) @map("reservations_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  bookings          Booking[]
  tenant            Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone], name: "uidx_tenant_customer_phone")
  @@map("customers")
}

model LoyaltyConfig {
  id                    String   @id @default(uuid())
  tenantId              String   @unique @map("tenant_id")
  reservationsForReward Int      @default(10) @map("reservations_for_reward")
  rewardDescription     String   @default("Free match (11th hour)") @map("reward_description")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("loyalty_configs")
}

model Booking {
  id              String     @id @default(uuid())
  tenantId        String     @map("tenant_id")
  fieldId         String     @map("field_id")
  customerId      String     @map("customer_id")
  createdBy       String     @map("created_by")
  reservationDate DateTime   @map("reservation_date")
  startTime       String     @map("start_time")
  endTime         String     @map("end_time")
  durationMinutes Int        @map("duration_minutes")
  totalAmount     Float      @map("total_amount")
  paidAmount      Float      @default(0.0) @map("paid_amount")
  paymentStatus   String     @default("unpaid") @map("payment_status")
  status          String     @default("confirmed")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  creator         TenantUser @relation(fields: [createdBy], references: [id])
  customer        Customer   @relation(fields: [customerId], references: [id])
  field           Field      @relation(fields: [fieldId], references: [id])
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  payments        Payment[]

  @@map("bookings")
}

model Payment {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  bookingId       String   @map("booking_id")
  amount          Float
  paymentMethod   String   @default("cash") @map("payment_method")
  referenceNumber String?  @map("reference_number")
  createdAt       DateTime @default(now()) @map("created_at")
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  fullName  String    @map("full_name")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
}
